echo  [—] Montando la carpeta en red con los activos bajo "A:\"...
net use A: \\IP.DEL.SERVIDOR.SMB\RUTA_CARPETA_COMPARTIDA_SMB /user:USUARIO "CONTRASEÑA" /persistent:no >nul

